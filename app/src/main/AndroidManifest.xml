<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Notification Listener Service Permission -->
    <uses-permission
        android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        android:protectionLevel="signature|privileged" />

    <!-- Vibration for the alarm action -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Foreground service that owns a ringing alarm (looping audio) until dismissed/snoozed -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Post the ongoing alarm notification with Dismiss/Snooze actions (Android 13+ runtime) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Raise the full-screen, call-style alarm UI over the lock screen (restricted on Android 14+) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Camera torch for the flash alert action - optional, FlashAlertActionExecutor checks
         availability at runtime and skips gracefully on devices without a flash -->
    <uses-feature
        android:name="android.hardware.camera.flash"
        android:required="false" />

    <!-- Query all packages - needed for Android 11+ to see installed apps -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Notificapp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Notificapp"
            android:enableOnBackInvokedCallback="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification Listener Service -->
        <service
            android:name=".features.notification.NotificappListenerService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Foreground service that owns a ringing CREATE_ALARM alarm: looping audio + repeating
             vibration + the ongoing Dismiss/Snooze notification, until the user acts on it. -->
        <service
            android:name=".core.notification.action.alarm.AlarmService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Full-screen, call-style alarm UI raised over the lock screen by AlarmService's
             full-screen intent. singleInstance + noHistory so it never stacks or lingers. -->
        <activity
            android:name=".features.alarm.ui.AlarmActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Notificapp" />

        <!-- Exposes cache/rule-exports/ as content:// URIs for sharing exported rule JSON via
             the share sheet, without granting broader file access. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
