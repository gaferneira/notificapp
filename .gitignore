# Build & tool caches
*.iml
.gradle
.kotlin/
/build
/captures
.externalNativeBuild
.cxx

# IDE & OS
/.idea/
.DS_Store

# Local environment — contains machine paths and secrets
local.properties

# Signing — never commit keystores or release credentials
*.jks
*.keystore

# Built artifacts outside build/ (e.g., copied for release)
*.apk
*.aab

# Personal agent config — never commit (machine-specific permissions/overrides)
.claude/settings.local.json
.agents/**/*_local.md
